{
  "expo": {
    "name": "GeniusLaw Attorney",
    "slug": "geniuslaw-attorney",
    "owner": "geniuslaw",
    "version": "1.2.0",
    "scheme": "geniuslawattorney",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.geniuslaw.attorney",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "GeniusLaw Attorney uses your microphone for in-app voice calls with clients.",
        "NSCameraUsageDescription": "GeniusLaw Attorney uses your camera for video calls with clients (optional, audio-only by default).",
        "UIBackgroundModes": [
          "audio",
          "voip"
        ]
      }
    },
    "android": {
      "package": "com.geniuslaw.attorney",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.READ_PHONE_STATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_PHONE_CALL",
        "android.permission.MANAGE_OWN_CALLS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-dev-client",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ],
      "@config-plugins/react-native-callkeep",
      "./plugins/withVoipPush",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./plugins/withFcmNotificationMeta",
      "./plugins/withAllowNonModularIncludes",
      "./plugins/withFirebaseModularHeaders",
      "@react-native-community/datetimepicker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "",
          "enableGooglePay": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13c7971c-46ec-40ea-861f-dc93cd14a86c"
      }
    }
  }
}
