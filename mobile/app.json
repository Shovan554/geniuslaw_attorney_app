{
  "expo": {
    "name": "GeniusLaw Attorney",
    "slug": "geniuslaw-attorney",
    "owner": "geniuslaw",
    "version": "1.0.0",
    "scheme": "geniuslawattorney",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.geniuslaw.attorney",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "GeniusLaw Attorney uses your microphone for in-app voice calls with clients.",
        "NSCameraUsageDescription": "GeniusLaw Attorney uses your camera for video calls with clients (optional, audio-only by default).",
        "UIBackgroundModes": [
          "audio",
          "voip"
        ]
      }
    },
    "android": {
      "package": "com.geniuslaw.attorney",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13c7971c-46ec-40ea-861f-dc93cd14a86c"
      }
    }
  }
}
