# ─── Secrets ────────────────────────────────────────────────
# Never commit these. Anyone with these can impersonate the app.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Vonage private key — pairs with the public key Vonage holds; if leaked,
# anyone can mint JWTs for any user in our Vonage Application.
**/vonage_private_key.*
**/vonage_*.key
**/vonage_*.pem

# Generic credentials people sometimes drop here
*.p12
*.pem
*.mobileprovision
secrets/

# ─── Python (backend) ───────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ─── Node / React Native / Expo (mobile) ────────────────────
node_modules/
.expo/
.expo-shared/
dist/
web-build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.metro-health-check*

# iOS
ios/Pods/
ios/build/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/

# Android
android/.gradle/
android/build/
android/app/build/
android/local.properties
*.keystore
!debug.keystore

# EAS Build
.easignore

# ─── OS / editor ────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
!.vscode/settings.json
!.vscode/launch.json
*.iml

# ─── Misc ───────────────────────────────────────────────────
coverage/
*.tmp

# Superpowers / SDD workflow artifacts (local only)
.superpowers/
docs/superpowers/
